{
  "manifest_version": 3,
  "name": "AI Ingest",
  "version": "1.0.0",
  "description": "Extract and export learning platform course structures, progress, and context into AI-ready Markdown, JSON, and prompt-optimized formats.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.udemy.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.udemy.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
